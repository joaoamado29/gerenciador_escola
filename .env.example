# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env no git

DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASSWORD=sua_senha_aqui
DB_HOST=127.0.0.1
DB_PORT=5432
DB_SSLMODE=require

# Senha inicial dos administradores (matrículas 0001, 0002, 0003).
# Usada apenas no primeiro start para criar os admins; trocada obrigatoriamente
# no primeiro login de cada admin. Defina um valor forte aqui e nunca commite.
ADMIN_SENHA_INICIAL=trocar-no-primeiro-login
